# App profile
SPRING_PROFILES_ACTIVE=prod

# Server
PORT=8080

# Database (Railway/Render/Supabase Postgres)
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/<db>
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# JWT (minimum 32 chars)
JWT_SECRET=replace-with-a-long-random-secret-value-at-least-32-characters
JWT_EXPIRATION_MS=86400000

# Comma separated frontend domains
APP_CORS_ALLOWED_ORIGINS=https://<your-frontend-domain>
